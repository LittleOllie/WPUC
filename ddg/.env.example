# Copy to `.env` in this folder (do NOT commit `.env`). Values from Firebase Console → Web app.
# Vite only exposes variables prefixed with VITE_.
#
# --- GitHub: env files are not in the repo on purpose ---
# For automatic deploys, add these as Repository secrets (same names / values as above):
#   GitHub repo → Settings → Secrets and variables → Actions → New repository secret
# See `.github/workflows/github-pages.yml` for the list. Then enable Pages → Source: GitHub Actions.
#
# GitHub Pages subpath: also set secret VITE_BASE_PATH=/your-repo-name/
# Or create `.env.production` locally with only VITE_BASE_PATH and run `npm run build` before upload.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
