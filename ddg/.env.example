# Vite base path for GitHub Pages project sites (trailing slash). Example: /my-repo/
# Default in local dev is usually "/"
VITE_BASE_PATH=/

# Firebase Web App config (Console → Project settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional; used for Analytics
VITE_FIREBASE_MEASUREMENT_ID=
