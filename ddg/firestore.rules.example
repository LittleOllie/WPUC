rules_version = '2';

// Deploy to Firebase Console → Firestore → Rules (or `firebase deploy --only firestore:rules`).
// If you previously used auto-generated document IDs, migrate or delete those docs so each row
// uses the normalized handle as the document ID (see client: doc(leaderboard, handle)).

service cloud.firestore {
  match /databases/{database}/documents {

    match /leaderboard/{docId} {
      // Public read
      allow read: if true;

      // Create: doc id must equal handle; server timestamp for createdAt
      allow create: if
        docId is string
        && docId.size() >= 1 && docId.size() <= 15
        && docId.matches('^[a-zA-Z0-9_]+$')
        && request.resource.data.keys().hasAll(['handle', 'score', 'character', 'scene', 'createdAt'])
        && request.resource.data.handle is string
        && request.resource.data.handle == docId
        && request.resource.data.score is int
        && request.resource.data.score >= 1
        && request.resource.data.score <= 10000000
        && request.resource.data.character is string
        && request.resource.data.scene is string
        && request.resource.data.character.size() <= 64
        && request.resource.data.scene.size() <= 64
        && request.resource.data.createdAt == request.time;

      // Update: handle + createdAt immutable; only score (strictly higher), character, scene
      allow update: if
        resource.data.handle == docId
        && request.resource.data.handle == resource.data.handle
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.score is int
        && request.resource.data.score > resource.data.score
        && request.resource.data.score >= 1
        && request.resource.data.score <= 10000000
        && request.resource.data.character is string
        && request.resource.data.scene is string
        && request.resource.data.character.size() <= 64
        && request.resource.data.scene.size() <= 64;

      allow delete: if false;
    }
  }
}
