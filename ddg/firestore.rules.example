// Paste into Firebase Console → Firestore Database → Rules (or deploy with Firebase CLI).
// Leaderboard doc IDs MUST equal `handle` (normalized: [a-zA-Z0-9_], length 1–15).
// After switching from random doc IDs, delete or migrate old `leaderboard` documents in Console.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{docId} {
      allow read: if true;

      allow create: if docId == request.resource.data.handle
        && request.resource.data.handle is string
        && request.resource.data.handle == docId
        && request.resource.data.handle.matches('^[a-zA-Z0-9_]{1,15}$')
        && request.resource.data.keys().hasAll(['handle', 'score', 'character', 'scene', 'createdAt'])
        && request.resource.data.handle.size() >= 1
        && request.resource.data.handle.size() <= 15
        && (request.resource.data.score is int || request.resource.data.score is float)
        && request.resource.data.score >= 1
        && request.resource.data.score <= 10000000
        && request.resource.data.character is string
        && request.resource.data.scene is string
        && request.resource.data.character.size() <= 64
        && request.resource.data.scene.size() <= 64
        && request.resource.data.createdAt == request.time;

      allow update: if docId == resource.data.handle
        && request.resource.data.handle == resource.data.handle
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score', 'character', 'scene'])
        && (request.resource.data.score is int || request.resource.data.score is float)
        && request.resource.data.score >= 1
        && request.resource.data.score <= 10000000
        && request.resource.data.score > resource.data.score
        && request.resource.data.character is string
        && request.resource.data.scene is string
        && request.resource.data.character.size() <= 64
        && request.resource.data.scene.size() <= 64;

      allow delete: if false;
    }
  }
}
