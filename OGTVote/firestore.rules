// Deploy: Firebase Console → Firestore → Rules, or `firebase deploy --only firestore:rules`
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /votes/{voteId} {
      allow read: if true;

      // New vote rooms only (no overwrites)
      allow create: if
        request.resource.data.code is string &&
        request.resource.data.name is string &&
        request.resource.data.createdBy is string;

      // OGTVote updates: lock/shuffle anytime; finish requires admin (creator)
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['locked', 'shuffle']) ||
        (
          resource.data.createdBy is string &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['locked', 'finished', 'finishedAt'])
        );

      allow delete: if false;

      match /entries/{entryId} {
        allow read: if true;

        allow create: if
          get(/databases/$(database)/documents/votes/$(voteId)).data.finished != true &&
          request.resource.data.tweetId is string &&
          request.resource.data.tweetUrl is string &&
          request.resource.data.image is string;

        allow delete: if true;
        allow update: if false;
      }

      // Ballots (same path name as in app: votes/{voteId}/votes/{ballotId})
      match /votes/{ballotId} {
        allow read: if true;

        // First save = create; change vote = update (set merge: true in app)
        allow create: if
          get(/databases/$(database)/documents/votes/$(voteId)).data.finished != true &&
          request.resource.data.selections is list;

        allow update: if
          get(/databases/$(database)/documents/votes/$(voteId)).data.finished != true &&
          request.resource.data.selections is list;

        allow delete: if false;
      }
    }
  }
}
